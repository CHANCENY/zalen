{#
/**
 * @file
 * Default view template to display all the fields in a row.
 *
 * Available variables:
 * - view: The view in use.
 * - fields: A list of fields, each one contains:
 *   - content: The output of the field.
 *   - raw: The raw data for the field, if it exists. This is NOT output safe.
 *   - class: The safe class ID to use.
 *   - handler: The Views field handler controlling this field.
 *   - inline: Whether or not the field should be inline.
 *   - wrapper_element: An HTML element for a wrapper.
 *   - wrapper_attributes: List of attributes for wrapper element.
 *   - separator: An optional separator that may appear before a field.
 *   - label: The field's label text.
 *   - label_element: An HTML element for a label wrapper.
 *   - label_attributes: List of attributes for label wrapper.
 *   - label_suffix: Colon after the label.
 *   - element_type: An HTML element for the field content.
 *   - element_attributes: List of attributes for HTML element for field content.
 *   - has_label_colon: A boolean indicating whether to display a colon after
 *     the label.
 *   - element_type: An HTML element for the field content.
 *   - element_attributes: List of attributes for HTML element for field content.
 * - row: The raw result from the query, with all data it fetched.
 *
 * @see template_preprocess_views_view_fields()
 *
 * @ingroup themeable
 */
#}
<style>
.provincie-view .view-content {
  padding: 24px 0;
}

.provincie-container{
  background:#fff;
  border-radius:16px;
  border:1px solid #e6e6e6;
  overflow:hidden;
  box-shadow: 
    0 2px 6px rgba(0,0,0,0.06),
    0 10px 24px rgba(0,0,0,0.08);
  transition: all 0.25s ease;
}

.provincie-foto{
  padding:12px;
}

.provincie-foto img{
  width:100%;
  min-height:210px;
  border-radius:12px;
  display:block;
}

.provincie-label{
  padding:6px 16px 0 16px;
}

.provincie-label h2{
  margin:0;
  font-size:17px;
  font-weight:700;
  color:var(--brand-color);
}

.provincie-label h2 a{
  text-decoration:none;
  color:var(--brand-color);
}

.provincie-label ion-icon {
  color:var(--brand-color) !important;
}

.provincie-city{
  display:flex;
  align-items:center;
  justify-content: space-between;
  gap:6px;
  font-size:13px;
  color:#777;
  padding:6px 16px 12px 16px;
}

.provincie-city ion-icon{
  font-size:14px;
}

.provincie-container .item-list ul{
  margin:0;
  padding:0;
}

.provincie-container .item-list ul li{
  list-style:none;
  margin:0;
  padding:0;
}

.provincie-zalen summary{
  background:#fcf7ca;
  color:#000;
  padding:12px 14px;
  font-size:14px;
  font-weight:600;
  cursor:pointer;
  display:flex;
  align-items:center;
  gap:8px;
}

.provincie-zalen summary::-webkit-details-marker{
  display:none;
}

.provincie-container summary::after{
  content:none !important;
}

.provincie-zalen summary::before{
  content:"▶";
  font-size:10px;
  color:#000;
}

.provincie-zalen details[open] summary::before{
  transform: rotate(90deg);
}

.provincie-zalen summary a{
  margin-left:auto;
  color: var(--brand-color);
  text-decoration: underline;
  border: unset;
}

.provincie-zalen summary a:hover{
  border: unset;
  color: var(--brand-color);
}
.provincie-zalen details {
  margin-top: 0.5em;
  margin-bottom: unset;
  border: unset;
}

.provincie-zalen details > div{
  background:#ffffff;
  display:flex;
  justify-content:space-around;
  align-items:center;
  padding:12px 10px;
  font-size:15px;
  border-top:1px solid #eee;
  color:#333;
}

.provincie-meer-details{
  border:none;
  margin: unset;
}

.provincie-meer-summary{
  cursor:pointer;
  background: unset;
  text-align: center;
  justify-content: center;
  border: unset !important;
}

.provincie-meer-summary p{
    text-decoration: underline;
}

.provincie-meer-zalen{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:6px;
  color:#1a9f60;
  font-weight:600;
  font-size:14px;
  margin: unset;
}

.provincie-meer-details[open] .provincie-meer-zalen ion-icon{
  transform: rotate(180deg);
}
@media (max-width:991px){
  .provincie-view .views-view-responsive-grid--horizontal{
    --views-responsive-grid--column-count: 2 !important;
  }
}

@media (max-width:767px){
  .provincie-view .views-view-responsive-grid--horizontal{
    --views-responsive-grid--column-count: 1 !important;
  }
}

@media (max-width:480px){

  .provincie-foto img{
    min-height:180px;
  }

  .provincie-label h2{
    font-size:16px;
  }

  .provincie-zalen summary{
    font-size:13px;
  }

}
</style>

<div class="provincie-container">

  <div class="provincie-foto">
    {{ fields.field_foto.content }}
  </div>
    <div class="provincie-label">
    <h2>{{ fields.title_1.content }}</h2>
  </div>
  <div class="provincie-city">
    <span><ion-icon style="color:#777" name="location-outline"></ion-icon>
    {{ fields.field_adres_locality.content }}</span>
    <span>{{ fields.field_google_place_id.content }}</span>
  </div>
  <div class="provincie-zalen">
    {{ fields.field_zaal_bedrijf.content }}
  </div>
  
  {% if fields.field_zaal_bedrijf_1.content|striptags|trim is not empty %}
  <details class="provincie-meer-details">
    <summary class="provincie-meer-summary">
      <p class="provincie-meer-zalen">{{ 'meer zalen'|t }}<ion-icon name="caret-down-sharp"></ion-icon></p>
    </summary>
    <div class="provincie-meer">  
      <div class="provincie-zalen">
      {{ fields.field_zaal_bedrijf_1.content }}
      </div>
    </div>
  </details>
  {% endif %}
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
  // Get all the containers for rooms
  const roomContainers = document.querySelectorAll(".provincie-container");

  // Iterate through each room container
  roomContainers.forEach((container) => {
    // Get the first details element inside the current room container
    const firstDetails = container.querySelector("details.provincie-eerstedrie");

    // If the first details element exists, open it
    if (firstDetails) {
      firstDetails.open = true;
    }
  });
});
</script>
